{
  "functions": {
    "api/hubspot.js":  { "maxDuration": 10 },
    "api/fetch.js":    { "maxDuration": 15 },
    "api/contact.js":  { "maxDuration": 15 },
    "api/hunter.js":   { "maxDuration": 10 }
  },
  "routes": [
    { "src": "/api/hubspot", "dest": "/api/hubspot.js" },
    { "src": "/api/fetch",   "dest": "/api/fetch.js" },
    { "src": "/api/contact", "dest": "/api/contact.js" },
    { "src": "/api/hunter",  "dest": "/api/hunter.js" },
    { "src": "/(.*)",        "dest": "/index.html" }
  ]
}
