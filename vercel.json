{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/hubspot.js", "use": "@vercel/node" },
    { "src": "api/scan.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/hubspot", "dest": "/api/hubspot.js" },
    { "src": "/api/scan", "dest": "/api/scan.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "functions": {
    "api/scan.js": { "maxDuration": 30 }
  }
}
